<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- ============================================================
         App-level theme-aware semantic colors (Light / Dark)
         Used via AppThemeBinding in XAML pages.
         ============================================================ -->

    <!-- Page / surface backgrounds -->
    <Color x:Key="PageBackground_Light">White</Color>
    <Color x:Key="PageBackground_Dark">#1A1A2E</Color>

    <Color x:Key="CardBackground_Light">#F5F5F5</Color>
    <Color x:Key="CardBackground_Dark">#2A2A3E</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary_Light">#1B1B1B</Color>
    <Color x:Key="TextPrimary_Dark">#ECECEC</Color>

    <Color x:Key="TextSecondary_Light">#6E6E6E</Color>
    <Color x:Key="TextSecondary_Dark">#A0A0B0</Color>

    <Color x:Key="TextMuted_Light">#919191</Color>
    <Color x:Key="TextMuted_Dark">#787890</Color>

    <!-- Semantic: error / badge / link -->
    <Color x:Key="ErrorText_Light">#D32F2F</Color>
    <Color x:Key="ErrorText_Dark">#EF5350</Color>

    <Color x:Key="BadgeText_Light">White</Color>
    <Color x:Key="BadgeText_Dark">#1B1B1B</Color>

    <!-- Buttons: primary CTA overrides (import button) -->
    <Color x:Key="PrimaryButtonBg_Light">#512BD4</Color>
    <Color x:Key="PrimaryButtonBg_Dark">#7C5AFF</Color>
    <Color x:Key="PrimaryButtonText_Light">White</Color>
    <Color x:Key="PrimaryButtonText_Dark">White</Color>

    <!-- Buttons: secondary / inverted (search button on home) -->
    <Color x:Key="SecondaryButtonBg_Light">#212121</Color>
    <Color x:Key="SecondaryButtonBg_Dark">#E1E1E1</Color>
    <Color x:Key="SecondaryButtonText_Light">White</Color>
    <Color x:Key="SecondaryButtonText_Dark">#1B1B1B</Color>

    <!-- Buttons: ghost / clear-filter -->
    <Color x:Key="GhostButtonText_Light">#6E6E6E</Color>
    <Color x:Key="GhostButtonText_Dark">#A0A0B0</Color>

    <!-- Semantic: success feedback -->
    <Color x:Key="SuccessText_Light">#2E7D32</Color>
    <Color x:Key="SuccessText_Dark">#66BB6A</Color>
</ResourceDictionary>