<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PartsCopilot.ViewModels"
             x:Class="PartsCopilot.Views.SearchPage"
             x:DataType="vm:SearchViewModel"
             Title="Search Parts"
             AutomationId="SearchPage">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16">

        <!-- Search Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,8">
            <Entry Placeholder="Part number or description..."
                   Text="{Binding QueryText}"
                   ReturnCommand="{Binding SearchCommand}"
                   ReturnType="Search"
                   FontSize="16"
                   ClearButtonVisibility="WhileEditing"
                   SemanticProperties.Description="Search input field"
                   SemanticProperties.Hint="Enter a part number or description to search"
                   AutomationId="SearchEntry" />
            <Button Grid.Column="1" Text="🔍"
                    Command="{Binding SearchCommand}"
                    Margin="8,0,0,0"
                    WidthRequest="50"
                    SemanticProperties.Description="Search"
                    SemanticProperties.Hint="Execute the parts search"
                    AutomationId="SearchButton" />
        </Grid>

        <!-- Filters -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" Margin="0,4,0,8"
                               SemanticProperties.Description="Search filters">
            <Picker Title="Model"
                    ItemsSource="{Binding AvailableModels}"
                    SelectedItem="{Binding SelectedModel}"
                    WidthRequest="120"
                    SemanticProperties.Description="Filter by vehicle model"
                    SemanticProperties.Hint="Select a model to narrow search results"
                    AutomationId="ModelFilterPicker" />
            <Picker Title="Year"
                    ItemsSource="{Binding AvailableYears}"
                    SelectedItem="{Binding SelectedYear}"
                    WidthRequest="100"
                    SemanticProperties.Description="Filter by year"
                    SemanticProperties.Hint="Select a year to narrow search results"
                    AutomationId="YearFilterPicker" />
            <Button Text="✕ Clear"
                    Command="{Binding ClearFiltersCommand}"
                    FontSize="12"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource GhostButtonText_Light}, Dark={StaticResource GhostButtonText_Dark}}"
                    Padding="4"
                    SemanticProperties.Description="Clear all filters"
                    SemanticProperties.Hint="Removes model and year filter selections"
                    AutomationId="ClearFiltersButton" />
        </HorizontalStackLayout>

        <!-- Results -->
        <Grid Grid.Row="2">

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsSearching}"
                               IsVisible="{Binding IsSearching}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               SemanticProperties.Description="Loading search results"
                               AutomationId="SearchLoadingIndicator" />

            <!-- No Results -->
            <VerticalStackLayout IsVisible="{Binding HasNoResults}"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="8"
                                 AutomationId="NoResultsPanel">
                <Label Text="No parts found" FontSize="18" HorizontalOptions="Center"
                       SemanticProperties.Description="No parts found for the search query"
                       AutomationId="NoResultsTitle" />
                <Label Text="Try a different search or adjust filters"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary_Light}, Dark={StaticResource TextSecondary_Dark}}"
                       HorizontalOptions="Center"
                       SemanticProperties.Description="Suggestion to refine the search"
                       AutomationId="NoResultsHint" />
            </VerticalStackLayout>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="{AppThemeBinding Light={StaticResource ErrorText_Light}, Dark={StaticResource ErrorText_Dark}}"
                   FontSize="14"
                   VerticalOptions="Center" HorizontalOptions="Center"
                   SemanticProperties.Description="Search error message"
                   AutomationId="SearchErrorLabel" />

            <!-- Result List -->
            <CollectionView ItemsSource="{Binding Results}"
                            IsVisible="{Binding HasResults}"
                            AutomationId="SearchResultsList">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchCandidateViewModel">
                        <Border Margin="0,4" Padding="12" Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground_Light}, Dark={StaticResource CardBackground_Dark}}"
                                AutomationId="SearchResultCard">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=ViewPartDetailsCommand}"
                                    CommandParameter="{Binding}" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                                <!-- Part Number -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding PartNumber}"
                                       FontSize="16" FontAttributes="Bold"
                                       FontFamily="OpenSansRegular"
                                       SemanticProperties.HeadingLevel="Level3"
                                       SemanticProperties.Description="Part number" />

                                <!-- Score Badge -->
                                <Border Grid.Row="0" Grid.Column="1"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryButtonBg_Light}, Dark={StaticResource PrimaryButtonBg_Dark}}"
                                        Padding="6,2" Stroke="Transparent"
                                        SemanticProperties.Description="Search relevance score">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Score}"
                                           TextColor="{AppThemeBinding Light={StaticResource BadgeText_Light}, Dark={StaticResource BadgeText_Dark}}"
                                           FontSize="11" />
                                </Border>

                                <!-- Description -->
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary_Light}, Dark={StaticResource TextSecondary_Dark}}"
                                       SemanticProperties.Description="Part description" />

                                <!-- Metadata Row -->
                                <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Spacing="12" Margin="0,4,0,0">
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                                           SemanticProperties.Description="Illustration reference">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="📋 " />
                                                <Span Text="{Binding Illustration, FallbackValue='-'}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                                           SemanticProperties.Description="Manual page number">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="📄 p." />
                                                <Span Text="{Binding PageNumber}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                                           Text="{Binding Quantity, StringFormat='Qty: {0}'}"
                                           IsVisible="{Binding Quantity, Converter={StaticResource IsNotNullConverter}}"
                                           SemanticProperties.Description="Quantity" />
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                                           Text="{Binding Model}"
                                           IsVisible="{Binding Model, Converter={StaticResource IsNotNullConverter}}"
                                           SemanticProperties.Description="Vehicle model" />
                                </HorizontalStackLayout>

                                <!-- Match Reason -->
                                <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding MatchReason}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                                       FontAttributes="Italic"
                                       Margin="0,2,0,0"
                                       SemanticProperties.Description="Why this part matched the search" />

                                <!-- Action Buttons -->
                                <HorizontalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Spacing="8" Margin="0,8,0,0">
                                    <Button Text="{Binding IsFavorite, Converter={StaticResource BoolToFavoriteIconConverter}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=ToggleFavoriteCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                                            Padding="8,4"
                                            MinimumWidthRequest="44"
                                            MinimumHeightRequest="44"
                                            SemanticProperties.Description="Toggle favorite" />
                                    <Button Text="📖 Open Page"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=OpenPageCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="12"
                                            BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                                            Padding="8,4"
                                            MinimumWidthRequest="44"
                                            MinimumHeightRequest="44"
                                            SemanticProperties.Description="Open manual page" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Status Bar -->
        <HorizontalStackLayout Grid.Row="3" Spacing="12" Padding="0,8"
                               IsVisible="{Binding HasResults}"
                               SemanticProperties.Description="Search results summary"
                               AutomationId="SearchStatusBar">
            <Label Text="{Binding TotalMatches, StringFormat='{0} results'}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                   SemanticProperties.Description="Total number of results"
                   AutomationId="ResultCountLabel" />
            <Label Text="{Binding SearchDuration}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextMuted_Light}, Dark={StaticResource TextMuted_Dark}}"
                   SemanticProperties.Description="Search duration"
                   AutomationId="SearchDurationLabel" />
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
