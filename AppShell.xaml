<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PartsCopilot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PartsCopilot.Views"
    Title="PartsCopilot"
    AutomationId="AppShell">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="{OnPlatform Default='🏠'}"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="home"
            AutomationId="HomeTab" />

        <ShellContent
            Title="Search"
            Icon="{OnPlatform Default='🔍'}"
            ContentTemplate="{DataTemplate views:SearchPage}"
            Route="search"
            AutomationId="SearchTab" />

        <ShellContent
            Title="Favorites"
            Icon="{OnPlatform Default='⭐'}"
            ContentTemplate="{DataTemplate views:FavoritesPage}"
            Route="favorites"
            AutomationId="FavoritesTab" />

        <ShellContent
            Title="Settings"
            Icon="{OnPlatform Default='⚙️'}"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="settings"
            AutomationId="SettingsTab" />
    </TabBar>

</Shell>
